# Copy this file to .env if you want to override local Docker defaults.
# Compose will use the inline defaults from docker-compose.yml when values are absent.

DATABASE_URL=postgresql://mdcms:mdcms@postgres:5432/mdcms
REDIS_URL=redis://redis:6379
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=mdcms-media
SMTP_HOST=mailhog
SMTP_PORT=1025

NODE_ENV=development
LOG_LEVEL=info
APP_VERSION=0.0.0
PORT=4000
SERVICE_NAME=mdcms-server

# Optional startup OIDC provider config.
# The value must be a JSON array of provider profiles.
# Providers are enabled by presence; no separate feature flag is used.
# Example:
# MDCMS_AUTH_OIDC_PROVIDERS=[{"providerId":"okta","issuer":"https://example.okta.com/oauth2/default","domain":"example.com","clientId":"okta-client-id","clientSecret":"okta-client-secret"}]

# Optional startup SAML provider config.
# The value must be a JSON array of provider profiles.
# Providers are enabled by presence; no separate feature flag is used.
# Example:
# MDCMS_AUTH_SAML_PROVIDERS=[{"providerId":"okta-saml","issuer":"https://www.okta.com/exk123456789","domain":"example.com","entryPoint":"https://example.okta.com/app/example/sso/saml","cert":"-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----","audience":"https://cms.example.com/saml/okta-saml/sp","spEntityId":"https://cms.example.com/saml/okta-saml/sp","attributeMapping":{"id":"nameID","email":"email","name":"displayName","firstName":"givenName","lastName":"surname"}}]
