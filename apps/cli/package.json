{
  "name": "@mdcms/cli",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "mdcms": "./dist/bin/mdcms.js"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@mdcms/source": "./src/index.ts",
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "nx": {
    "name": "cli"
  },
  "scripts": {
    "test": "bun test ./src",
    "dev": "bun --conditions @mdcms/source src/bin/mdcms.ts --help"
  },
  "dependencies": {
    "@elysiajs/eden": "^1.4.8",
    "@mdcms/modules": "workspace:*",
    "@mdcms/shared": "workspace:*",
    "elysia": "^1.4.25",
    "tslib": "^2.3.0",
    "yaml": "^2.8.2"
  },
  "license": "MIT"
}
