{
  "name": "@mdcms/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@mdcms/source": "./src/index.ts",
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "nx": {
    "name": "server"
  },
  "scripts": {
    "test": "bun test ./src",
    "start": "bun --conditions @mdcms/source src/bin/http-server.ts",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.ts"
  },
  "dependencies": {
    "@mdcms/modules": "workspace:*",
    "@mdcms/shared": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "elysia": "^1.4.25",
    "postgres": "^3.4.8",
    "tslib": "^2.3.0"
  },
  "license": "MIT",
  "devDependencies": {
    "drizzle-kit": "^0.31.9"
  }
}
