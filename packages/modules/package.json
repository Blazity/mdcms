{
  "name": "@mdcms/modules",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@mdcms/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "nx": {
    "name": "modules",
    "targets": {
      "test": {
        "executor": "nx:run-commands",
        "options": {
          "command": "bun test packages/modules/src/index.test.ts"
        }
      }
    }
  },
  "dependencies": {
    "@mdcms/shared": "workspace:*",
    "tslib": "^2.3.0"
  },
  "license": "MIT"
}
