{
  "name": "@mdcms/sdk",
  "version": "0.1.3",
  "description": "Client SDK for MDCMS",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/mdcms-ai/mdcms.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/mdcms-ai/mdcms#readme",
  "bugs": "https://github.com/mdcms-ai/mdcms/issues",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@mdcms/source": "./src/index.ts",
      "bun": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./react": {
      "@mdcms/source": "./src/react.ts",
      "bun": "./src/react.ts",
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "default": "./dist/react.js"
    }
  },
  "nx": {
    "name": "sdk"
  },
  "scripts": {
    "prepack": "node ../../scripts/strip-dev-export-conditions.js",
    "postpack": "node ../../scripts/restore-package-json.js",
    "test": "bun test ./src"
  },
  "dependencies": {
    "@mdcms/shared": "^0.2.0",
    "@mdx-js/mdx": "^3.1.1",
    "tslib": "^2.3.0"
  },
  "peerDependencies": {
    "react": "^19.2.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "license": "MIT",
  "devDependencies": {
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.5",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  }
}
