{
  "name": "@mdcms/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "@mdcms/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "nx": {
    "name": "server",
    "targets": {
      "test": {
        "executor": "nx:run-commands",
        "options": {
          "command": "bun test packages/server/src/lib/health.test.ts"
        }
      }
    }
  },
  "scripts": {
    "start": "bun --conditions @mdcms/source src/bin/http-server.ts"
  },
  "dependencies": {
    "@mdcms/shared": "workspace:*",
    "tslib": "^2.3.0"
  },
  "license": "MIT"
}
