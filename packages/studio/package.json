{
  "name": "@mdcms/studio",
  "version": "0.1.3",
  "description": "Embeddable Studio UI component for MDCMS",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Blazity/mdcms.git",
    "directory": "packages/studio"
  },
  "homepage": "https://github.com/Blazity/mdcms#readme",
  "bugs": "https://github.com/Blazity/mdcms/issues",
  "exports": {
    "./package.json": "./package.json",
    "./action-catalog-adapter": {
      "@mdcms/source": "./src/lib/action-catalog-adapter.ts",
      "types": "./dist/lib/action-catalog-adapter.d.ts",
      "import": "./dist/lib/action-catalog-adapter.js",
      "default": "./dist/lib/action-catalog-adapter.js"
    },
    "./build-runtime": {
      "@mdcms/source": "./src/lib/build-runtime.ts",
      "types": "./dist/lib/build-runtime.d.ts",
      "import": "./dist/lib/build-runtime.js",
      "default": "./dist/lib/build-runtime.js"
    },
    "./document-shell": {
      "@mdcms/source": "./src/lib/document-shell.ts",
      "types": "./dist/lib/document-shell.d.ts",
      "import": "./dist/lib/document-shell.js",
      "default": "./dist/lib/document-shell.js"
    },
    "./markdown-pipeline": {
      "@mdcms/source": "./src/lib/markdown-pipeline.ts",
      "types": "./dist/lib/markdown-pipeline.d.ts",
      "import": "./dist/lib/markdown-pipeline.js",
      "default": "./dist/lib/markdown-pipeline.js"
    },
    "./runtime": {
      "@mdcms/source": "./src/lib/studio.ts",
      "types": "./dist/lib/studio.d.ts",
      "import": "./dist/lib/studio.js",
      "default": "./dist/lib/studio.js"
    },
    ".": {
      "@mdcms/source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "nx": {
    "name": "studio",
    "targets": {
      "build": {
        "executor": "nx:run-commands",
        "options": {
          "command": "rm -rf packages/studio/dist/assets packages/studio/dist/bootstrap && bun tsc --build packages/studio/tsconfig.lib.json && bun --conditions @mdcms/source packages/studio/src/lib/build-runtime.ts"
        }
      }
    }
  },
  "scripts": {
    "dev": "sh -lc 'trap \"kill 0\" INT TERM EXIT; bun x --bun tsc --build tsconfig.lib.json --watch --preserveWatchOutput & bun --conditions @mdcms/source src/lib/dev-runtime-watch.ts & wait'",
    "test": "bun test ./src"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@elysiajs/eden": "^1.4.8",
    "@floating-ui/react-dom": "^2.1.8",
    "@fontsource-variable/geist-mono": "^5.2.7",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@mdcms/shared": "^0.1.3",
    "@radix-ui/react-avatar": "1.1.11",
    "@radix-ui/react-checkbox": "1.3.3",
    "@radix-ui/react-collapsible": "1.1.12",
    "@radix-ui/react-dialog": "1.1.15",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-popover": "1.1.15",
    "@radix-ui/react-scroll-area": "1.2.10",
    "@radix-ui/react-select": "2.2.6",
    "@radix-ui/react-separator": "1.1.8",
    "@radix-ui/react-slot": "1.2.4",
    "@radix-ui/react-switch": "1.2.6",
    "@radix-ui/react-tabs": "1.1.13",
    "@radix-ui/react-tooltip": "1.2.8",
    "@tailwindcss/postcss": "^4.2.0",
    "@tanstack/react-query": "^5.96.2",
    "@tiptap/core": "^3.7.0",
    "@tiptap/extension-highlight": "^3.7.0",
    "@tiptap/extension-image": "^3.7.0",
    "@tiptap/extension-link": "^3.7.0",
    "@tiptap/extension-placeholder": "^3.7.0",
    "@tiptap/extension-task-item": "^3.7.0",
    "@tiptap/extension-task-list": "^3.7.0",
    "@tiptap/extension-typography": "^3.7.0",
    "@tiptap/extension-underline": "^3.7.0",
    "@tiptap/markdown": "^3.7.0",
    "@tiptap/react": "^3.7.0",
    "@tiptap/starter-kit": "^3.7.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "4.1.0",
    "elysia": "^1.4.25",
    "lucide-react": "^1.7.0",
    "postcss": "^8.5.6",
    "react-day-picker": "9.13.2",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.2.0",
    "tslib": "^2.3.0",
    "tw-animate-css": "1.3.3"
  },
  "devDependencies": {
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.5",
    "next": "^15.2.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "license": "MIT"
}
