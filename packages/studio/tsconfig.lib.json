{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/lib/runtime-ui/*"],
      "next/link": ["src/lib/runtime-ui/adapters/next-link.tsx"],
      "next/navigation": ["src/lib/runtime-ui/adapters/next-navigation.ts"],
      "next-themes": ["src/lib/runtime-ui/adapters/next-themes.tsx"]
    },
    "rootDir": "src",
    "outDir": "dist",
    "tsBuildInfoFile": "dist/tsconfig.lib.tsbuildinfo",
    "jsx": "react-jsx",
    "lib": ["es2022", "dom", "dom.iterable"],
    "emitDeclarationOnly": false,
    "forceConsistentCasingInFileNames": true,
    "types": ["node", "react", "react-dom"]
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "references": [
    {
      "path": "../shared/tsconfig.lib.json"
    }
  ]
}
